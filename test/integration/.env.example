# Integration-test wallets + endpoints.
# Copy to `test/integration/.env` and fill in. NEVER commit the real .env.
#
#   cp test/integration/.env.example test/integration/.env
#   npm run test:integration
#
# Only test-network funds. Do NOT put a mainnet mnemonic here.

# ---- Pre-funded test wallets (REQUIRED — without these every suite skips) ----
# Alice: funded on Spark regtest, Liquid testnet, Arkade mutinynet, RGB-L1 mutinynet.
ALICE_MNEMONIC=""
# Bob: funded on the same networks (send-test counterparty).
BOB_MNEMONIC=""

# ---- Opt-in: run the Alice -> Bob send/transfer tests (moves test funds) ----
# RUN_SEND_TESTS=1

# ---- Skip individual protocols (optional) ----
# SKIP_SPARK=1
# SKIP_LIQUID=1
# SKIP_ARKADE=1
# SKIP_RGB_L1=1

# ---- Endpoint overrides (optional — defaults target the public test networks) ----
# Liquid testnet Esplora
# LIQUID_ESPLORA_URL="https://blockstream.info/liquidtestnet/api"

# Arkade on Mutinynet (signet)
# ARKADE_SERVER_URL="https://mutinynet.arkade.sh"
# ARKADE_ESPLORA_URL="https://mutinynet.com/api"
# ARKADE_DELEGATOR_URL="https://delegator.mutinynet.arkade.sh"

# RGB-L1 (rgb-lib) on Mutinynet (signet)
# RGB_INDEXER_URL="https://mutinynet.com/api"
# RGB_TRANSPORT_ENDPOINT="rpcs://proxy.iriswallet.com/0.2/json-rpc"
# RGB_DATA_DIR="/tmp/wallet-engine-it/rgb"
