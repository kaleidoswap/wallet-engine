{
  "name": "@kaleidorg/wallet-engine",
  "version": "1.0.0-beta.4",
  "description": "Multi-protocol Bitcoin L2 wallet engine (Spark · RGB/RLN · Liquid · Arkade) — native or WDK-backed adapters behind one IProtocolAdapter contract, with a cross-protocol router, BIP321 unified receive, and lite/advanced disclosure.",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "clean": "rm -rf dist",
    "prepublishOnly": "npm run build"
  },
  "files": [
    "dist"
  ],
  "dependencies": {
    "kaleido-sdk": "^0.1.6",
    "@scure/bip39": "^1.4.0",
    "@scure/bip32": "^1.5.0"
  },
  "optionalDependencies": {
    "@buildonspark/spark-sdk": "*",
    "@arkade-os/sdk": "*",
    "@flashnet/sdk": "*",
    "@tetherto/wdk-wallet-spark": "^1.0.0-beta.17",
    "@kaleidorg/wdk-wallet-rln": "^1.0.0-beta.2",
    "@kaleidorg/wdk-wallet-liquid": "^1.0.0-beta.2",
    "@kaleidorg/wdk-protocol-swap-kaleidoswap": "^1.0.0-beta.2"
  },
  "devDependencies": {
    "@buildonspark/spark-sdk": "^0.7.10",
    "@arkade-os/sdk": "^0.4.14",
    "@flashnet/sdk": "^0.5.7",
    "typescript": "~5.9.3"
  },
  "publishConfig": {
    "access": "public"
  },
  "license": "MIT"
}
